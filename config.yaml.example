# Cloud Media 配置文件示例
# 复制为 config.yaml 并根据实际情况修改

server:
  host: 0.0.0.0
  port: 8080

log:
  level: info  # debug, info, warn, error
  format: json # json, text

database:
  host: localhost
  port: 5432
  user: postgres
  password: password
  dbname: media-db
  sslmode: disable

rabbitmq:
  url: amqp://guest:guest@localhost:5672/

# 对象存储配置（支持 MinIO、AWS S3、Cloudflare R2）
# type: minio, s3, r2
object_storage:
  type: minio
  internal_endpoint: localhost:9000
  internal_use_ssl: false
  external_endpoint: localhost:9000
  external_use_ssl: false
  access_key_id: rootadmin
  secret_access_key: rootpassword
  region: us-east-1  # R2 使用 "auto"

  # CDN 配置（可选）
  cdn:
    enabled: false
    base_url: "https://cdn.example.com"
    # url_signing_secret: ""  # 用于 CDN URL 签名（可选）

# 兼容性配置（保留旧格式，会被 object_storage 覆盖）
minio:
  internal_endpoint: localhost:9000
  internal_use_ssl: false
  external_endpoint: localhost:9000
  external_use_ssl: false
  access_key_id: rootadmin
  secret_access_key: rootpassword

observability:
  service_name: cloud-media
  service_version: 1.0.0

  metrics:
    enabled: true
    path: /metrics
    port: 9090

  tracing:
    enabled: true
    exporter: otlp           # otlp, stdout, none
    otlp_endpoint: localhost:4317
    sampler: always_on      # always_on, always_off, traceidratio
    sampler_ratio: 1.0
